generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model album_events {
  id         Int       @id @default(autoincrement())
  album_id   Int
  vendor_id  Int
  name       String    @db.VarChar(120)
  sort_order Int?      @default(0)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  albums     albums    @relation(fields: [album_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  photos     photos[]
}

model album_settings {
  vendor_id             Int     @id
  pw_prefix             String? @default("") @db.VarChar(40)
  spw_prefix            String? @default("") @db.VarChar(40)
  instructions_template String?
}

model albums {
  id               Int              @id @default(autoincrement())
  vendor_id        Int
  title            String           @db.VarChar(160)
  category         String?          @db.VarChar(80)
  cover_photo      String?          @db.VarChar(300)
  guest_username   String?          @db.VarChar(80)
  guest_password   String?          @db.VarChar(120)
  admin_username   String?          @db.VarChar(80)
  admin_password   String?          @db.VarChar(120)
  created_at       DateTime?        @default(now()) @db.Timestamp(6)
  exp_enabled      Boolean?         @default(false)
  exp_from_date    DateTime?        @db.Date
  exp_date         DateTime?        @db.Date
  exp_notes        String?
  client_email     String?          @db.VarChar(160)
  face_ai          Boolean?         @default(false)
  public_token     String?          @unique @db.VarChar(40)
  gallery_mode     String?          @db.VarChar(20)
  faces_clustered  Boolean?         @default(false)
  face_engine_lock String?          @db.VarChar(10)
  cover_focus      String?          @default("50% 50%") @db.VarChar(20)
  album_events     album_events[]
  face_clusters    face_clusters[]
  favorites        favorites[]
  photos           photos[]
  selection_notes  selection_notes?
  selections       selections[]

  @@index([vendor_id], map: "idx_albums_vendor")
}

model chatbot_knowledge {
  vendor_id     Int       @id
  business_name String?   @db.VarChar(160)
  tagline       String?   @db.VarChar(240)
  service_area  String?   @db.VarChar(240)
  contact       String?   @db.VarChar(240)
  hours         String?   @db.VarChar(240)
  services      String?
  packages      String?
  faqs          String?
  policies      String?
  notes         String?
  updated_at    DateTime? @default(now()) @db.Timestamp(6)
  about_team    String?
  languages     String?   @db.VarChar(240)
  avoid_topics  String?
  tone_notes    String?
  delivery_time String?   @db.VarChar(240)
  vendors       vendors   @relation(fields: [vendor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model chatbot_messages {
  id         Int       @id @default(autoincrement())
  vendor_id  Int
  message    String
  name       String?   @db.VarChar(160)
  contact    String?   @db.VarChar(160)
  status     String?   @default("unread") @db.VarChar(20)
  session    String?   @db.VarChar(64)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  vendors    vendors   @relation(fields: [vendor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model chatbot_pending {
  id         Int       @id @default(autoincrement())
  vendor_id  Int
  question   String
  answer     String?
  status     String?   @default("pending") @db.VarChar(20)
  session    String?   @db.VarChar(64)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  vendors    vendors   @relation(fields: [vendor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model chatbot_subscribers {
  id            Int       @id @default(autoincrement())
  vendor_id     Int       @unique
  active        Boolean?  @default(true)
  share_token   String?   @unique @db.VarChar(24)
  access_code   String?   @db.VarChar(60)
  subscribed_at DateTime? @default(now()) @db.Timestamp(6)
  vendors       vendors   @relation(fields: [vendor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model chatbot_transcripts {
  id         Int       @id @default(autoincrement())
  vendor_id  Int
  session    String    @db.VarChar(64)
  role       String    @db.VarChar(12)
  content    String
  created_at DateTime? @default(now()) @db.Timestamp(6)
  vendors    vendors   @relation(fields: [vendor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([created_at], map: "idx_cbt_created")
  @@index([vendor_id, session, id], map: "idx_cbt_vendor_session")
}

model chatbot_usage {
  id            Int       @id @default(autoincrement())
  vendor_id     Int
  session       String?   @db.VarChar(64)
  input_tokens  Int?      @default(0)
  output_tokens Int?      @default(0)
  cost_usd      Decimal?  @default(0) @db.Decimal(10, 6)
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  vendors       vendors   @relation(fields: [vendor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([vendor_id, created_at], map: "idx_cbusage_vendor")
}

model contract_audit {
  id          Int       @id @default(autoincrement())
  contract_id Int
  event       String    @db.VarChar(40)
  ip          String?   @db.VarChar(64)
  meta        Json?
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  contracts   contracts @relation(fields: [contract_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([contract_id], map: "idx_ctaudit")
}

model contract_templates {
  id          Int       @id @default(autoincrement())
  vendor_id   Int
  name        String    @default("My Contract") @db.VarChar(120)
  event_type  String?   @db.VarChar(100)
  header      String?   @default("")
  body        String    @default("")
  legal_terms String?   @default("")
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  updated_at  DateTime? @default(now()) @db.Timestamp(6)
  vendors     vendors   @relation(fields: [vendor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([vendor_id], map: "idx_cttpl_vendor")
}

model contracts {
  id             Int              @id @default(autoincrement())
  vendor_id      Int
  lead_id        Int
  token          String           @unique @db.VarChar(64)
  title          String?          @default("Service Agreement") @db.VarChar(200)
  body           String
  status         String?          @default("draft") @db.VarChar(20)
  signed_name    String?          @db.VarChar(200)
  signed_ip      String?          @db.VarChar(64)
  signed_at      DateTime?        @db.Timestamp(6)
  created_at     DateTime?        @default(now()) @db.Timestamp(6)
  updated_at     DateTime?        @default(now()) @db.Timestamp(6)
  signature_data String?
  initials       Json?            @default("[]")
  viewed_at      DateTime?        @db.Timestamp(6)
  doc_sha256     String?          @db.VarChar(64)
  contract_audit contract_audit[]
  leads          leads            @relation(fields: [lead_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  vendors        vendors          @relation(fields: [vendor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([lead_id], map: "idx_ct_lead")
  @@index([token], map: "idx_ct_token")
}

model crew_members {
  id         Int         @id @default(autoincrement())
  vendor_id  Int
  name       String      @db.VarChar(120)
  role       String?     @db.VarChar(80)
  phone      String?     @db.VarChar(40)
  email      String?     @db.VarChar(200)
  created_at DateTime?   @default(now()) @db.Timestamp(6)
  vendors    vendors     @relation(fields: [vendor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  lead_crew  lead_crew[]

  @@index([vendor_id], map: "idx_crew_vendor")
}

model email_settings {
  vendor_id    Int       @id
  mode         String?   @default("platform") @db.VarChar(20)
  smtp_host    String?   @db.VarChar(200)
  smtp_port    Int?      @default(587)
  smtp_user    String?   @db.VarChar(200)
  smtp_pass    String?   @db.VarChar(300)
  from_name    String?   @db.VarChar(120)
  from_email   String?   @db.VarChar(200)
  notify_email String?   @db.VarChar(200)
  updated_at   DateTime? @default(now()) @db.Timestamp(6)
  vendors      vendors   @relation(fields: [vendor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model email_templates {
  id         Int       @id @default(autoincrement())
  vendor_id  Int
  name       String    @db.VarChar(120)
  subject    String    @db.VarChar(200)
  body       String
  created_at DateTime? @default(now()) @db.Timestamp(6)
  vendors    vendors   @relation(fields: [vendor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([vendor_id], map: "idx_et_vendor")
}

model face_clusters {
  id             Int           @id @default(autoincrement())
  album_id       Int
  vendor_id      Int
  engine         String?       @db.VarChar(20)
  centroid       Json?
  cover_photo_id Int?
  cover_box      Json?
  photo_count    Int?          @default(0)
  created_at     DateTime?     @default(now()) @db.Timestamp(6)
  albums         albums        @relation(fields: [album_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  photo_faces    photo_faces[]

  @@index([album_id, photo_count(sort: Desc)], map: "idx_fc_album")
}

model favorites {
  id         Int       @id @default(autoincrement())
  album_id   Int
  photo_id   Int
  email      String    @db.VarChar(160)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  albums     albums    @relation(fields: [album_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  photos     photos    @relation(fields: [photo_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([album_id, photo_id, email])
  @@index([album_id], map: "idx_favorites_album")
  @@index([album_id, email], map: "idx_favorites_album_email")
}

model gallery_theme {
  vendor_id     Int     @id
  heading_font  String? @default("Playfair Display") @db.VarChar(60)
  body_font     String? @default("Jost") @db.VarChar(60)
  bg_color      String? @default("#0f1115") @db.VarChar(9)
  heading_color String? @default("#f3f4f6") @db.VarChar(9)
  accent_color  String? @default("#2dd4bf") @db.VarChar(9)
  sub_color     String? @default("#9ca3af") @db.VarChar(9)
  title_text    String? @default("Client Galleries") @db.VarChar(120)
  subtitle_text String? @default("Secure, Password-Protected Memories") @db.VarChar(160)
  tagline_text  String? @default("Ready to view, share and download.") @db.VarChar(200)
  default_mode  String? @default("per_event") @db.VarChar(20)
}

model inquiry_settings {
  vendor_id          Int       @id
  brand_name         String?   @db.VarChar(120)
  brand_color        String?   @default("#2dd4bf") @db.VarChar(20)
  intro_text         String?   @default("Tell us about your event 💫") @db.VarChar(300)
  show_phone         Boolean?  @default(true)
  show_guests        Boolean?  @default(true)
  show_times         Boolean?  @default(true)
  show_location      Boolean?  @default(true)
  show_getting_ready Boolean?  @default(true)
  show_notes         Boolean?  @default(true)
  event_types        Json?     @default("[\"Wedding\", \"Engagement\", \"Portrait\", \"Event\", \"Other\"]")
  updated_at         DateTime? @default(now()) @db.Timestamp(6)
  custom_fields      Json?     @default("[]")
  theme              String?   @default("classic") @db.VarChar(30)
  font               String?   @default("Inter") @db.VarChar(60)
  details_heading    String?   @default("Event Details") @db.VarChar(200)
  background         String?   @default("none") @db.VarChar(30)
  intro_link         String?   @default("") @db.VarChar(300)
  vendors            vendors   @relation(fields: [vendor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model invoices {
  id             Int       @id @default(autoincrement())
  vendor_id      Int
  lead_id        Int
  token          String    @unique @db.VarChar(64)
  invoice_number String    @db.VarChar(30)
  items          Json?     @default("[]")
  subtotal       Decimal?  @default(0) @db.Decimal(10, 2)
  discount       Decimal?  @default(0) @db.Decimal(10, 2)
  total          Decimal?  @default(0) @db.Decimal(10, 2)
  paid           Decimal?  @default(0) @db.Decimal(10, 2)
  balance        Decimal?  @default(0) @db.Decimal(10, 2)
  notes          String?   @db.VarChar(300)
  status         String?   @default("issued") @db.VarChar(20)
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  leads          leads     @relation(fields: [lead_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  vendors        vendors   @relation(fields: [vendor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([lead_id], map: "idx_inv_lead")
  @@index([vendor_id], map: "idx_inv_vendor")
}

model lead_crew {
  id             Int          @id @default(autoincrement())
  lead_id        Int
  crew_member_id Int
  duty           String?      @db.VarChar(120)
  arrive_time    String?      @db.VarChar(20)
  leave_time     String?      @db.VarChar(20)
  checkin_token  String?      @unique @db.VarChar(64)
  checked_in_at  DateTime?    @db.Timestamp(6)
  checked_out_at DateTime?    @db.Timestamp(6)
  created_at     DateTime?    @default(now()) @db.Timestamp(6)
  crew_members   crew_members @relation(fields: [crew_member_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  leads          leads        @relation(fields: [lead_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([lead_id], map: "idx_lc_lead")
}

model leads {
  id                  Int              @id @default(autoincrement())
  vendor_id           Int?
  name                String?          @db.VarChar(200)
  email               String?          @db.VarChar(200)
  phone               String?          @db.VarChar(50)
  event_type          String?          @db.VarChar(100)
  event_date          DateTime?        @db.Date
  timing_from         String?          @db.VarChar(20)
  timing_to           String?          @db.VarChar(20)
  location            String?          @db.VarChar(300)
  hours               Int?
  guests              Int?
  gr_bride            Boolean?         @default(false)
  gr_bride_venue      String?          @db.VarChar(300)
  gr_groom            Boolean?         @default(false)
  gr_groom_venue      String?          @db.VarChar(300)
  notes               String?
  internal_notes      String?
  status              String?          @default("new") @db.VarChar(50)
  created_at          DateTime?        @default(now()) @db.Timestamp(6)
  updated_at          DateTime?        @default(now()) @db.Timestamp(6)
  package_id          Int?
  package_snapshot    Json?
  deposit_percent     Int?             @default(30)
  discount_percent    Decimal?         @default(0) @db.Decimal(5, 2)
  price_override      Decimal?         @db.Decimal(10, 2)
  archived_at         DateTime?        @db.Timestamp(6)
  billed              Boolean?         @default(false)
  delivered           Boolean?         @default(false)
  booking_notes       String?
  ceremony            String?
  client_token        String?          @unique @db.VarChar(64)
  custom_data         Json?            @default("{}")
  role                String?          @db.VarChar(50)
  instagram           String?          @db.VarChar(120)
  heard               String?          @db.VarChar(120)
  gateway_enabled     Boolean?         @default(false)
  web_payment_enabled Boolean?         @default(true)
  timer_enabled       Boolean?         @default(false)
  timer_hours         Int?             @default(72)
  timer_started_at    DateTime?        @db.Timestamptz(6)
  contracts           contracts[]
  invoices            invoices[]
  lead_crew           lead_crew[]
  vendor_packages     vendor_packages? @relation(fields: [package_id], references: [id], onUpdate: NoAction)
  vendors             vendors?         @relation(fields: [vendor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  payments            payments[]

  @@index([vendor_id], map: "idx_leads_vendor")
}

model notifications {
  id         Int       @id @default(autoincrement())
  vendor_id  Int
  type       String?   @default("info") @db.VarChar(40)
  title      String    @db.VarChar(200)
  body       String?   @db.VarChar(400)
  seen_at    DateTime? @db.Timestamp(6)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  vendors    vendors   @relation(fields: [vendor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([vendor_id, seen_at], map: "idx_notif_vendor")
}

model offers {
  id          Int       @id @default(autoincrement())
  code        String    @unique @db.VarChar(50)
  label       String?   @db.VarChar(120)
  percent_off Int
  active      Boolean?  @default(true)
  starts_at   DateTime? @db.Date
  ends_at     DateTime? @db.Date
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  applies_to  String?   @default("all") @db.VarChar(40)

  @@index([code], map: "idx_offers_code")
}

model package_items {
  id                   Int      @id @default(autoincrement())
  package_id           Int
  name                 String   @db.VarChar(120)
  icon                 String?  @db.VarChar(20)
  detail               String?  @db.VarChar(200)
  price_monthly        Decimal? @db.Decimal(8, 2)
  price_annual         Decimal? @db.Decimal(8, 2)
  price_annual_regular Decimal? @db.Decimal(8, 2)
  is_addon             Boolean? @default(false)
  is_included          Boolean? @default(false)
  sort_order           Int?     @default(0)
  packages             packages @relation(fields: [package_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([package_id], map: "idx_pkg_items_pkg")
}

model package_templates {
  id              Int               @id @default(autoincrement())
  vendor_id       Int
  name            String            @default("My Event") @db.VarChar(120)
  sort_order      Int?              @default(1)
  created_at      DateTime?         @default(now()) @db.Timestamp(6)
  vendors         vendors           @relation(fields: [vendor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  vendor_packages vendor_packages[]

  @@index([vendor_id], map: "idx_ptpl_vendor")
}

model packages {
  id                   Int             @id @default(autoincrement())
  key                  String          @unique @db.VarChar(50)
  name                 String          @db.VarChar(120)
  tagline              String?         @db.VarChar(200)
  icon                 String?         @db.VarChar(20)
  price_monthly        Decimal?        @db.Decimal(8, 2)
  price_annual         Decimal?        @db.Decimal(8, 2)
  price_annual_regular Decimal?        @db.Decimal(8, 2)
  trial_days           Int?            @default(30)
  sort_order           Int?            @default(0)
  country_prices       Json?           @default("{}")
  package_items        package_items[]
}

model password_reset_tokens {
  id         Int       @id @default(autoincrement())
  user_id    Int
  token_hash String
  expires_at DateTime  @db.Timestamptz(6)
  used_at    DateTime? @db.Timestamptz(6)
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([token_hash], map: "idx_prt_token_hash")
  @@index([user_id], map: "idx_prt_user")
}

model payments {
  id         Int       @id @default(autoincrement())
  vendor_id  Int
  lead_id    Int
  amount     Decimal   @db.Decimal(10, 2)
  method     String?   @default("manual") @db.VarChar(40)
  note       String?   @db.VarChar(200)
  paid_at    DateTime? @default(now()) @db.Timestamp(6)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  leads      leads     @relation(fields: [lead_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  vendors    vendors   @relation(fields: [vendor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([lead_id], map: "idx_pay_lead")
  @@index([vendor_id], map: "idx_pay_vendor")
}

model photo_faces {
  cluster_id    Int
  photo_id      Int
  face_clusters face_clusters @relation(fields: [cluster_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  photos        photos        @relation(fields: [photo_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([cluster_id, photo_id])
  @@index([photo_id], map: "idx_pf_photo")
}

model photos {
  id           Int           @id @default(autoincrement())
  album_id     Int
  vendor_id    Int
  filename     String?       @db.VarChar(200)
  storage_path String?       @db.VarChar(400)
  thumb_path   String?       @db.VarChar(400)
  is_selected  Boolean?      @default(false)
  selected_at  DateTime?     @db.Timestamp(6)
  created_at   DateTime?     @default(now()) @db.Timestamp(6)
  preview_path String?       @db.VarChar(400)
  faces        Json?
  face_indexed Boolean?      @default(false)
  face_count   Int?          @default(0)
  event_id     Int?
  face_engine  String?       @db.VarChar(20)
  favorites    favorites[]
  photo_faces  photo_faces[]
  albums       albums        @relation(fields: [album_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  album_events album_events? @relation(fields: [event_id], references: [id], onUpdate: NoAction)
  selections   selections[]

  @@index([album_id], map: "idx_photos_album")
  @@index([vendor_id], map: "idx_photos_vendor")
}

model plan_features {
  plan_id     Int
  feature_key String @db.VarChar(40)
  plans       plans  @relation(fields: [plan_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([plan_id, feature_key])
}

model plans {
  id                   Int                    @id @default(autoincrement())
  code                 String                 @unique @db.VarChar(40)
  name                 String                 @db.VarChar(120)
  price_monthly        Decimal                @db.Decimal(8, 2)
  created_at           DateTime?              @default(now()) @db.Timestamp(6)
  plan_features        plan_features[]
  vendor_subscriptions vendor_subscriptions[]
}

model platform_settings {
  key        String    @id @db.VarChar(60)
  value      String?
  updated_at DateTime? @default(now()) @db.Timestamp(6)
}

model poll_votes {
  id         Int       @id @default(autoincrement())
  choice     String    @db.VarChar(120)
  ip         String    @unique @db.VarChar(64)
  created_at DateTime? @default(now()) @db.Timestamp(6)
}

model referrals {
  id               Int       @id @default(autoincrement())
  referrer_email   String    @db.VarChar(200)
  friend_email     String    @db.VarChar(200)
  status           String?   @default("pending") @db.VarChar(30)
  reward           String?   @default("1 free month") @db.VarChar(60)
  friend_vendor_id Int?
  created_at       DateTime? @default(now()) @db.Timestamp(6)
  rewarded_at      DateTime? @db.Timestamp(6)
  vendors          vendors?  @relation(fields: [friend_vendor_id], references: [id], onUpdate: NoAction)

  @@index([friend_email], map: "idx_ref_friend")
  @@index([referrer_email], map: "idx_ref_referrer")
}

model selection_notes {
  album_id     Int       @id
  note         String?
  updated_at   DateTime? @default(now()) @db.Timestamp(6)
  completed_at DateTime? @db.Timestamp(6)
  albums       albums    @relation(fields: [album_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model selections {
  id         Int       @id @default(autoincrement())
  album_id   Int
  photo_id   Int
  created_at DateTime? @default(now()) @db.Timestamp(6)
  albums     albums    @relation(fields: [album_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  photos     photos    @relation(fields: [photo_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([album_id, photo_id])
  @@index([album_id], map: "idx_selections_album")
}

model services {
  id                   Int               @id @default(autoincrement())
  name                 String            @db.VarChar(100)
  icon                 String?           @db.VarChar(20)
  price                Decimal           @db.Decimal(8, 2)
  is_addon             Boolean?          @default(false)
  requires_service_id  Int?
  feature_key          String?           @unique @db.VarChar(40)
  price_annual         Decimal?          @db.Decimal(8, 2)
  price_annual_regular Decimal?          @db.Decimal(8, 2)
  tiers                Json?
  country_prices       Json?             @default("{}")
  services             services?         @relation("servicesToservices", fields: [requires_service_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  other_services       services[]        @relation("servicesToservices")
  vendor_services      vendor_services[]
}

model support_messages {
  id         Int       @id @default(autoincrement())
  vendor_id  Int?
  from_email String?   @db.VarChar(160)
  subject    String?   @db.VarChar(200)
  body       String?
  status     String?   @default("open") @db.VarChar(20)
  seen       Boolean?  @default(false)
  created_at DateTime? @default(now()) @db.Timestamp(6)
}

model trial_signups {
  id         Int       @id @default(autoincrement())
  ip_address String    @db.VarChar(64)
  email      String?   @db.VarChar(200)
  vendor_id  Int?
  created_at DateTime? @default(now()) @db.Timestamp(6)
  vendors    vendors?  @relation(fields: [vendor_id], references: [id], onUpdate: NoAction)

  @@index([ip_address], map: "idx_trial_ip")
}

model users {
  id                    Int                     @id @default(autoincrement())
  name                  String                  @db.VarChar(200)
  email                 String                  @unique @db.VarChar(200)
  password_hash         String                  @db.VarChar(255)
  role                  String                  @default("vendor") @db.VarChar(50)
  vendor_id             Int?
  created_at            DateTime?               @default(now()) @db.Timestamp(6)
  password_reset_tokens password_reset_tokens[]
  vendors               vendors?                @relation(fields: [vendor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([vendor_id], map: "idx_users_vendor")
}

model vendor_feature_overrides {
  id          Int       @id @default(autoincrement())
  vendor_id   Int
  feature_key String    @db.VarChar(40)
  enabled     Boolean
  updated_at  DateTime? @default(now()) @db.Timestamp(6)
  vendors     vendors   @relation(fields: [vendor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([vendor_id, feature_key])
}

model vendor_packages {
  id                Int                @id @default(autoincrement())
  vendor_id         Int
  name              String             @default("My Package") @db.VarChar(120)
  base_price        Decimal?           @default(0) @db.Decimal(10, 2)
  included_hours    Int?               @default(0)
  per_hour_price    Decimal?           @default(0) @db.Decimal(10, 2)
  inclusions        Json?              @default("[]")
  is_default        Boolean?           @default(false)
  sort_order        Int?               @default(1)
  created_at        DateTime?          @default(now()) @db.Timestamp(6)
  updated_at        DateTime?          @default(now()) @db.Timestamp(6)
  template_id       Int?
  leads             leads[]
  package_templates package_templates? @relation(fields: [template_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  vendors           vendors            @relation(fields: [vendor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([vendor_id], map: "idx_vpkg_vendor")
}

model vendor_services {
  id         Int      @id @default(autoincrement())
  vendor_id  Int
  service_id Int
  enabled    Boolean? @default(true)
  services   services @relation(fields: [service_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  vendors    vendors  @relation(fields: [vendor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([vendor_id, service_id])
  @@index([vendor_id], map: "idx_vendor_services_vendor")
}

model vendor_settings {
  vendor_id   Int       @id
  time_format String?   @default("12h") @db.VarChar(5)
  timezone    String?   @default("America/Vancouver") @db.VarChar(80)
  theme       String?   @default("dark") @db.VarChar(10)
  updated_at  DateTime? @default(now()) @db.Timestamp(6)
  vendors     vendors   @relation(fields: [vendor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model vendor_subscriptions {
  id         Int       @id @default(autoincrement())
  vendor_id  Int
  plan_id    Int
  status     String?   @default("active") @db.VarChar(20)
  started_at DateTime? @default(now()) @db.Timestamp(6)
  ends_at    DateTime? @db.Timestamp(6)
  plans      plans     @relation(fields: [plan_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vendors    vendors   @relation(fields: [vendor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([vendor_id, status], map: "idx_vsub_vendor")
}

model vendors {
  id                       Int                        @id @default(autoincrement())
  business_name            String                     @db.VarChar(200)
  plan                     String?                    @default("starter") @db.VarChar(50)
  status                   String?                    @default("trial") @db.VarChar(50)
  storage_mb               Int?                       @default(0)
  country                  String?                    @db.VarChar(100)
  created_at               DateTime?                  @default(now()) @db.Timestamp(6)
  signup_ip                String?                    @db.VarChar(60)
  seen_by_admin            Boolean?                   @default(false)
  logo_path                String?                    @default("") @db.VarChar(300)
  phone                    String?                    @default("") @db.VarChar(60)
  email                    String?                    @default("") @db.VarChar(160)
  gallery_token            String?                    @unique @db.VarChar(40)
  chatbot_knowledge        chatbot_knowledge?
  chatbot_messages         chatbot_messages[]
  chatbot_pending          chatbot_pending[]
  chatbot_subscribers      chatbot_subscribers?
  chatbot_transcripts      chatbot_transcripts[]
  chatbot_usage            chatbot_usage[]
  contract_templates       contract_templates[]
  contracts                contracts[]
  crew_members             crew_members[]
  email_settings           email_settings?
  email_templates          email_templates[]
  inquiry_settings         inquiry_settings?
  invoices                 invoices[]
  leads                    leads[]
  notifications            notifications[]
  package_templates        package_templates[]
  payments                 payments[]
  referrals                referrals[]
  trial_signups            trial_signups[]
  users                    users[]
  vendor_feature_overrides vendor_feature_overrides[]
  vendor_packages          vendor_packages[]
  vendor_services          vendor_services[]
  vendor_settings          vendor_settings?
  vendor_subscriptions     vendor_subscriptions[]
}
