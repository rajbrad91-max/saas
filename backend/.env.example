# ─────────────────────────────────────────────────────────────
#  iwopo backend — environment template
#
#  Copy this file to `.env` and fill in the real values:
#      cp .env.example .env
#
#  ⚠️  `.env` is gitignored (it holds real secrets) so it does NOT
#      travel with a git clone or a deploy. Every new server must
#      have its own `.env` created from this template.
# ─────────────────────────────────────────────────────────────

# ── Server ──────────────────────────────────────────────────
PORT=3001                       # live=3001, staging=3002
NODE_ENV=production

# ── PostgreSQL (used by the legacy pg pool + as the source of DATABASE_URL) ──
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-db-password-here
DB_NAME=iwopo                   # live=iwopo, staging=iwopo_staging

# ── Prisma connection ───────────────────────────────────────
# REQUIRED. Same credentials as above, in one URL.
# If this is missing you get a confusing error that looks like a password
# problem but isn't:
#     SASL: SCRAM-SERVER-FIRST-MESSAGE: client password must be a string
# Special characters in the password must be URL-encoded (@ becomes %40, etc).
DATABASE_URL="postgresql://postgres:your-db-password-here@localhost:5432/iwopo?schema=public"

# ── Auth ────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string

# ── File storage ────────────────────────────────────────────
STORAGE_BASE=/var/www/iwopo-storage   # where galleries/logos are written

# ── Public URL (used in emailed links: password reset, portal) ──
APP_URL=https://iwopo.com

# ── Platform SMTP (optional) ────────────────────────────────
# Not configured yet. Until these are set, password-reset emails
# respond with "platform email is not set up yet" instead of sending.
PLATFORM_SMTP_HOST=
PLATFORM_SMTP_PORT=587
PLATFORM_SMTP_USER=
PLATFORM_SMTP_PASS=
PLATFORM_FROM=noreply@iwopo.com
